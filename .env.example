# Copy to .env and fill in. NEVER commit .env (and per project rule, nothing is committed).

# --- Database ---
POSTGRES_USER=noey
POSTGRES_PASSWORD=change_me
POSTGRES_DB=noey_tiktok
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- LLM gateway (provider-agnostic) ---
# Cloud examples: anthropic/claude-opus-4-8 | openai/gpt-... | gemini/...
# Local examples: ollama/llama3  (set LLM_BASE_URL to your endpoint)
LLM_MODEL=anthropic/claude-opus-4-8
# LLM_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=
# LLM_WEB_SEARCH_ENABLED=true   # Anthropic native web search (default: on)
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- Speech-to-text (Whisper) ---
# Set to your deployed Modal endpoint to use GPU transcription; unset = local faster-whisper.
# MODAL_WHISPER_URL=
# WHISPER_LANGUAGE=th            # force language ("" = auto-detect, risks drift)

# --- Gemini transcript refine pass (hybrid: Whisper owns timing, Gemini fixes text) ---
# After Whisper transcribes, Gemini LISTENS to the same audio and corrects mis-heard
# Thai words + flags stutter/repeat/dead-air segments to cut. Timestamps always come
# from Whisper — Gemini never sees or returns them. Needs GEMINI_API_KEY set.
# GEMINI_REFINE_ENABLED=true      # set false to run Whisper-only
# GEMINI_REFINE_MODEL=gemini-3.5-flash

# --- Auth (JWT) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev_change_me_in_production
JWT_ACCESS_TTL=1800       # 30 min
JWT_REFRESH_TTL=1209600   # 14 days
ALLOW_REGISTRATION=false

# --- Encryption (Fernet) for API keys stored in DB ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# --- Background workers (arq / Redis) ---
# In docker-compose: REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://localhost:6380/0   # host port 6380 maps to container 6379

# --- Scrape cadence (seconds). User-set, but clamped to the enforced floor in code. ---
SCRAPE_INTERVAL=3600          # own-data scrape interval
MARKET_SCRAPE_INTERVAL=21600  # external market-trend scrape interval
