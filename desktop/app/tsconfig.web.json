{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "../node-sidecar/src/compositions/**/*"
  ],
  "exclude": [
    "../node-sidecar/src/compositions/Root.tsx",
    "../node-sidecar/src/compositions/index.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "@fx/*": [
        "../node-sidecar/src/compositions/*"
      ],
      "@fx-fonts/*": [
        "../node-sidecar/public/fonts/*"
      ]
    }
  }
}
