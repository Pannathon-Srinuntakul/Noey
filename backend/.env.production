# Railway production — paste into Shared Variables (api + worker).
# Prefer Railway references over hardcoded hostnames:
#   POSTGRES_HOST=${{Postgres.PGHOST}}  etc.
#   REDIS_URL=${{Redis.REDIS_URL}}

# --- Database ---
POSTGRES_USER=noey
POSTGRES_PASSWORD=change_me
POSTGRES_DB=noey_tiktok
POSTGRES_HOST=noey-postgres.railway.internal
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://noey-redis.railway.internal:6379/0

# --- CORS (public URL of the web service) ---
FRONTEND_URL=https://noey-web.railway.app

# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
ALLOW_REGISTRATION=false

# --- LLM ---
LLM_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_VISION_MODEL=anthropic/claude-sonnet-4-6
LLM_VISION_EFFORT=medium
LLM_WEB_SEARCH_ENABLED=true
ANTHROPIC_API_KEY=

# --- Modal Whisper (GPU transcription — deploy: modal deploy services/modal_whisper/app.py) ---
MODAL_WHISPER_URL=https://pabeam27--noey-whisper-transcribe-endpoint.modal.run

# --- S3 / Cloudflare R2 (required when worker has 2+ replicas; optional on single worker) ---
S3_BUCKET=noey-videos
S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# --- Encryption for AI keys stored in DB (optional) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# --- Whisper language (sent to Modal; also used if MODAL_WHISPER_URL is unset) ---
WHISPER_LANGUAGE=th

# Local faster-whisper fallback — only if MODAL_WHISPER_URL is blank (omit on Railway):
# WHISPER_MODEL=large-v3-turbo
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE=int8
